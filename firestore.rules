rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isDeveloper() { 
      return isSignedIn() && 
             request.auth.token.email == "klutchkanobi@gmail.com" && 
             request.auth.token.email_verified == true; 
    }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) || 
        isDeveloper()
      ); 
    }
    
    // 1. Customer Schema & Rules
    function isValidCustomer(data) {
      return data.keys().hasAll(['name', 'phoneNumber', 'loyaltyPoints', 'createdAt']) &&
             data.keys().size() <= 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phoneNumber is string && data.phoneNumber.size() >= 10 && data.phoneNumber.size() <= 15 &&
             data.loyaltyPoints is number && data.loyaltyPoints >= 0 &&
             data.createdAt == request.time;
    }

    match /customers/{customerId} {
      allow get: if isSignedIn() && (request.auth.uid == customerId);
      allow create: if isSignedIn() && (request.auth.uid == customerId) && isValidCustomer(incoming());
      // Updates are restricted to only loyaltyPoints and only by the application logic
      // In a real app, this should be a Cloud Function. 
      // For this applet, we'll allow it if schema is preserved.
      allow update: if isSignedIn() && (request.auth.uid == customerId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['loyaltyPoints', 'updatedAt']) &&
                    incoming().loyaltyPoints is number &&
                    incoming().updatedAt == request.time;
    }

    // 2. Orders Schema & Rules
    function isValidOrder(data) {
      return data.keys().hasAll(['customerName', 'items', 'status', 'total', 'createdAt']) &&
             data.customerName is string &&
             data.items is list && data.items.size() > 0 &&
             data.status in ["Order Received", "Preparing", "Out for Delivery", "Delivered", "Ready for Pickup"] &&
             data.total is number && data.total >= 0 &&
             data.createdAt == request.time;
    }

    match /orders/{orderId} {
      allow get: if isSignedIn(); // Customers can track their orders if they have the ID
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid);
      allow create: if isSignedIn() && isValidOrder(incoming());
      // Only status and updates allowed for tracking
      allow update: if isSignedIn() && 
                    (incoming().status != existing().status || incoming().updatedAt != existing().updatedAt) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'estimatedDeliveryTime']) &&
                    incoming().updatedAt == request.time;
    }

    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isDeveloper() && (request.auth.uid == adminId); 
    }
  }
}
